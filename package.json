{
  "name": "relayclip",
  "private": true,
  "version": "2026.3.15",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "version:calver": "node ./scripts/set-calver.mjs",
    "android:prepare": "node ./scripts/prepare-android-build.mjs",
    "android:debug:apk": "node ./scripts/build-android-debug.mjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "pnpm version:calver && tauri build",
    "tauri:android:init": "tauri android init --ci",
    "tauri:android:dev": "tauri android dev",
    "tauri:android:build": "pnpm version:calver && tauri android build --apk --aab --split-per-abi",
    "tauri:ios:init": "tauri ios init --ci",
    "tauri:ios:dev": "tauri ios dev",
    "tauri:ios:build": "pnpm version:calver && tauri ios build --export-method app-store-connect",
    "release:android": "pnpm version:calver && tauri android build --ci --apk --aab --split-per-abi",
    "release:ios": "pnpm version:calver && tauri ios build --ci --export-method app-store-connect"
  },
  "devDependencies": {
    "@lucide/svelte": "^0.577.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2.10.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.0",
    "svelte": "^5.53.7",
    "svelte-check": "^4.4.5",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  }
}

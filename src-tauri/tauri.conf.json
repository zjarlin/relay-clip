{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RelayClip",
  "version": "0.1.0",
  "identifier": "com.relayclip.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "RelayClip",
        "label": "main",
        "width": 460,
        "height": 780,
        "minWidth": 420,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "Clipboard relay for macOS and Windows on the same LAN.",
    "category": "Productivity",
    "windows": {
      "nsis": {}
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
